# ============================================================================
# RENTAKAR / AUTORENT — Environment Variables
# ============================================================================
# Kopjo kete skedar si `.env` dhe vendos vlerat reale.
# Skedari `.env` NUK duhet te futet ne git (eshte ne .gitignore).
# ============================================================================

# ----------------------------------------------------------------------------
# CLIENT-SIDE (Vite) — keto kalojne ne bundle, duhet te jene PUBLIC
# ----------------------------------------------------------------------------

# Supabase project URL (gjeje ne: Supabase Dashboard > Project Settings > API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (jo service role!)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Stripe publishable key (fillon me pk_test_ ose pk_live_)
# Gjeje ne: Stripe Dashboard > Developers > API keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Site URL — perdoret per redirects pas Stripe checkout
VITE_SITE_URL=http://localhost:5173

# Cloudflare Turnstile (CAPTCHA) - site key (public)
# Sign up: https://dash.cloudflare.com → Turnstile → Add site
# Pa kete vlere, CAPTCHA jo aktiv (dev mode)
VITE_TURNSTILE_SITE_KEY=0x4AAAAAAA...

# Sentry DSN (error monitoring)
# Sign up: https://sentry.io → Create React project → kopjo DSN
# Pa kete vlere, Sentry jo aktiv
VITE_SENTRY_DSN=https://...@o....ingest.sentry.io/...

# App version (perdoret nga Sentry per release tracking)
VITE_APP_VERSION=1.0.0

# VAPID public key per Web Push notifications
# Gjenerohet me: `node scripts/generate-vapid-keys.cjs`
# E njejta vlere ruhet edhe si edge function secret VAPID_PUBLIC_KEY.
VITE_VAPID_PUBLIC_KEY=BF_4uFV...

# Demo accounts ne LoginPage (Admin/Company/Client butona)
# Lëne false ose mos e vendos fare ne production -> demo accounts fshihen.
# Vendos true vetem nese do qe testues te jashtem te perdorin demo accounts.
# Demo buttons gjithmone shfaqen ne dev mode (npm run dev), pavaresisht kesaj.
# VITE_SHOW_DEMO_ACCOUNTS=false

# ============================================================================
# SUPABASE EDGE FUNCTION SECRETS
# ============================================================================
# Keto NUK shkojne ne `.env`. Vendosi ne Supabase Dashboard:
#   Project Settings > Edge Functions > Secrets
# Ose me CLI: `supabase secrets set RESEND_API_KEY=re_...`
# ============================================================================

# --- Supabase (te auto-injektuara ne edge functions, por mund t'i overrides) ---
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   # KUJDES: KURRE mos e ekspozosh client-side

# --- Resend (email transactional) ---
# Sign up: https://resend.com  →  API Keys  →  Create
# RESEND_API_KEY=re_...

# Adresa nga e cila do te dergohen email-et (duhet te jete domain i verifikuar ne Resend)
# RESEND_FROM_EMAIL=RentaKar <no-reply@rentcars.life>

# Adresa per reply-to (ku do te kthehen pergjigjet e klienteve)
# RESEND_REPLY_TO=info@rentcars.life

# --- Stripe ---
# Sign up: https://stripe.com  →  Developers  →  API Keys
# STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret (nga: Stripe Dashboard > Developers > Webhooks > Add endpoint)
# Endpoint URL duhet te jete: https://your-project-ref.supabase.co/functions/v1/stripe-webhook
# STRIPE_WEBHOOK_SECRET=whsec_...

# --- PayPal ---
# Sign up: https://developer.paypal.com > My Apps & Credentials > Create App
# PAYPAL_CLIENT_ID=AYSq...
# PAYPAL_SECRET=EH4t...
# Set to "live" per production, "sandbox" per testim
# PAYPAL_ENV=sandbox

# --- CORS allowed origins (vergulluar) ---
# CORS_ALLOWED_ORIGINS=https://rentcars.life,http://localhost:5173

# --- Web Push (VAPID) ---
# Gjeneroji me: `node scripts/generate-vapid-keys.cjs`
# Public key duhet te jete I NJEJTI me VITE_VAPID_PUBLIC_KEY ne client.
# VAPID_PUBLIC_KEY=BF_4uFV...
# VAPID_PRIVATE_KEY=OEACMH...
# VAPID_SUBJECT=mailto:contact@rentcars.life

# --- Stripe Identity (OCR verifikim patente) ---
# Nese Stripe Identity perdoret, krijo nje webhook te dyte vetem per kete
# event ne Stripe Dashboard. Eventet: identity.verification_session.*
# STRIPE_IDENTITY_WEBHOOK_SECRET=whsec_...

# --- Cron / scheduled tasks ---
# Krijuar nga migrations ne Supabase Vault si 'cron_secret'.
# Verifikohet ne scheduled-tasks edge function.
# CRON_SECRET=<auto-generated ne Vault>

# --- Currency rates fallback (kur ECB API s'pergjigjet) ---
# Vetem rates EUR -> X (jo USD/GBP qe i merr ECB direkt)
# ECB_FALLBACK_ALL=101.50
# ECB_FALLBACK_MKD=61.65
# ECB_FALLBACK_RSD=117.20

# --- Site URL (per sitemap edge function) ---
# SITE_URL=https://rentcars.life

# --- Sentry source maps (CI vetem; vendos ne GitHub Secrets) ---
# SENTRY_AUTH_TOKEN=<sentry org auth token, scope: project:releases>
# SENTRY_ORG=<sentry org slug>
# SENTRY_PROJECT=<sentry project slug>
